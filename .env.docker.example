# Copy this file to .env before running docker compose, then replace placeholders.
# Never commit a real .env file.

FRONTEND_HOST_PORT=8080
BACKEND_HOST_PORT=5000
SQLSERVER_HOST_PORT=14333
SQLSERVER_DATABASE=JewelleryEcommerce
SQLSERVER_SA_PASSWORD=Change_This_Strong_SQL_Password_123!

ASPNETCORE_ENVIRONMENT=Development
CATALOG_SEED_ENABLED=true
ADMIN_SEED_ENABLED=true
ADMIN_SEED_EMAIL=admin@gmail.com
ADMIN_SEED_PASSWORD=Change_This_Admin_Password_123!
ADMIN_SEED_FULL_NAME=Markety Admin

JWT_KEY=Change_This_To_A_Long_Random_JWT_Key_At_Least_32_Chars
JWT_ISSUER=Ecommercev1
JWT_AUDIENCE=EcommerceUsers

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_NAME=Markety

STRIPE_SECRET_KEY=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

AI_ASSISTANT_ENABLED=true
AI_ASSISTANT_PROVIDER=Gemini
AI_ASSISTANT_API_KEY=
AI_ASSISTANT_MODEL=gemini-flash-lite-latest
AI_ASSISTANT_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent
AI_ASSISTANT_TIMEOUT_SECONDS=30
